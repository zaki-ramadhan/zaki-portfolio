rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{project} {
      // Siapapun bisa baca untuk melihat portfolio
      allow read: if true;
      // Hanya user yang login (Anda) yang bisa mengelola data
      allow write: if request.auth != null;
    }
  }
}
